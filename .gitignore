# =========================================================
# Root .gitignore for: Login System (backend + frontend)
# Location: Capstone Project/Login System/.gitignore
# =========================================================

# ---------- Secrets / environment ----------
.env
**/.env
.env.*
!.env.example

# ---------- Python / Flask ----------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyd
*.pyo

# Virtual environments (yours is backend/venv)
venv/
.venv/
backend/venv/

# Python build / tooling
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- Database / runtime files ----------
# Your sqlite file (ignore it unless you explicitly want it tracked)
*.db
*.sqlite
*.sqlite3

# ---------- Node / Vite / Vue (frontend) ----------
node_modules/
frontend/node_modules/
dist/
frontend/dist/
dist-ssr/
frontend/dist-ssr/

*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ---------- Editor / OS ----------
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Visual Studio / Windows noise
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?