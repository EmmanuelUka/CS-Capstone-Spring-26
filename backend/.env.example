# ==============================
# Environment
# ==============================
# development | production
APP_ENV=development
VITE_API_URL=http://localhost:5000

# ==============================
# Flask Configuration
# ==============================
FLASK_SECRET_KEY=your-flask-secret-key-here
FRONTEND_URL=http://localhost:5173
FLASK_DEBUG=0

# ==============================
# Cookies / Sessions
# ==============================
SESSION_HOURS=8
SESSION_SAMESITE=Lax
# Set to 1 in production (HTTPS required)
COOKIE_SECURE=0

# Optional advanced cookie settings
# SESSION_COOKIE_DOMAIN=
# SESSION_COOKIE_PATH=/

# ==============================
# Reverse proxy / HTTPS
# ==============================
# If deploying behind a reverse proxy (nginx, Render, Fly.io, etc.)
USE_PROXY_FIX=1
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=0

# If your app correctly sees https (after ProxyFix), you can force https redirects + HSTS
FORCE_HTTPS=0

# ==============================
# CORS
# ==============================
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173


# ==============================
# Microsoft OAuth Configuration
# ==============================
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback

# Optional domain allowlist (comma-separated). Empty means allow any domain.
ALLOWED_EMAIL_DOMAINS=kent.edu

# ==============================
# Super Admin Control Panel
# ==============================
# Comma-separated list. Add/remove here (then restart backend).
SUPER_ADMIN_EMAILS=it-admin1@kent.edu,it-admin2@kent.edu

# If 1, any DB user with role SUPER_ADMIN not in SUPER_ADMIN_EMAILS gets demoted to ADMIN on startup.
# Safety: if SUPER_ADMIN_EMAILS is empty, no demotions occur.
ENFORCE_SUPER_ADMIN_LIST=1

# ==============================
# Rate Limits
# ==============================
RATE_LIMIT_DEFAULT=300 per hour
RATE_LIMIT_LOGIN=30 per minute
RATE_LIMIT_CALLBACK=60 per minute
RATE_LIMIT_ADD_USER=20 per minute
RATE_LIMIT_LOGOUT=30 per minute

# ==============================
# Sensitive data protection (DB)
# ==============================
# IMPORTANT:
# - EMAIL_HASH_PEPPER: a long random secret string (keep private)
# - EMAIL_ENC_KEY_B64: base64 for 32 random bytes (AES-256-GCM key)
#
# To generate a key (Python):
#   import os, base64
#   print(base64.b64encode(os.urandom(32)).decode())
EMAIL_HASH_PEPPER=change-me-to-a-long-random-secret
EMAIL_ENC_KEY_B64=change-me-to-generated-base64-32-bytes

# ==============================
# Security Logging / Monitoring
# ==============================
# LOG_FILE is optional. If set, a rotating log file will be created automatically.
# Leave blank to log only to console (recommended for containers).
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)s | %(message)s
LOG_FILE=logs/security.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# Separate secret used only for pseudonymous log identifiers.
# Must be different from FLASK_SECRET_KEY and EMAIL_HASH_PEPPER.
LOG_PSEUDO_KEY=change-me-to-a-long-random-secret

# Optional: include masked emails in logs for readability.
# 1 = yes, 0 = no
LOG_INCLUDE_MASKED_EMAILS=1
